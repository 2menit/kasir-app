# ── Database ──────────────────────────────────────────────────────────────
# These feed BOTH docker-compose.yml (${VAR} interpolation) and the Prisma
# DATABASE_URL below (Prisma expands ${VAR} via dotenv-expand). Single source.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photobooth
DB_PORT=5433

# Connection string used by Prisma — built from the values above.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${DB_PORT}/${POSTGRES_DB}?schema=public"

# ── Auth (NextAuth) ──────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Seed superadmin (used by prisma/seed.ts) ─────────────────────────────
SEED_SUPERADMIN_NAME=
SEED_SUPERADMIN_USERNAME=
SEED_SUPERADMIN_PASSWORD=
